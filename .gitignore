
# Ignore
# No trailing slash: also catches a node_modules path that happens to be
# a symlink or regular file (a stray symlink slipped past `node_modules/`
# once and got committed — every mentat git pull then re-materialized a
# broken self-referencing link). Same reasoning as score-relay below.
node_modules
scratch/
/storage/
data/
*.un~
.*.un~

client/
scratch/

# only ignore the cache at the root level
/cache/

# Playwright
e2e/.auth/
playwright-report/
test-results/

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# tsc
*.tsbuildinfo

# CodeRush
.cr/

# test
coverage
/storage/

# eslint
.eslintcache

# General
.DS_Store
.AppleDouble
.LSOverride

# Local
.env
dist
build
.webpack

# Storybook
storybook-static/

# Admin client build output
admin-client/dist/
admin-client/node_modules

# Staged by mentat-push-server.sh during deploy.
# On mentat-dev, this is a symlink to ../epixodic/score-relay so that
# ecosystem.config.js's relative `score-relay/dist/server.js` path
# resolves locally without duplicating node_modules. Pattern with no
# trailing slash matches both the directory (on nest) and the symlink
# (on mentat).
score-relay
# Runtime locale cache lives at the project-root i18n/ — anchor with the
# leading slash so it doesn't also swallow src/modules/i18n/.
/i18n/
