{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "modules/account/email/templates/**/*",
        "outDir": "build/src"
      },
      {
        "include": "modules/fonts/assets/**/*",
        "outDir": "build/src"
      }
    ],
    "watchAssets": true
  }
}
