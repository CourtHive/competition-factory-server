# SERVER_PROFILE='full'                        # 'tournament' | 'provider' | 'full' (default)
APP_NAME='Competition Factory Server'
APP_MODE='development'
APP_PORT='8383'

# URL where the TMX client app is served — used by the admin client for
# the "Impersonate → open in TMX" handoff. Both apps must share an origin
# for the localStorage handoff to work. Defaults to '/tmx/' which matches
# the standard prod layout (admin at /admin/, TMX at /tmx/).
TMX_URL='/tmx/'

JWT_SECRET=''                                  # set to a long random string
JWT_VALIDITY='2h'

TRACKER_CACHE='cache'

REDIS_TTL='28800000'
REDIS_URL='redis://localhost:6379'
REDIS_HOST='localhost'
REDIS_USERNAME=''
REDIS_PASSWORD=''
REDIS_PORT='6379'

PG_HOST='localhost'
PG_PORT='5432'
PG_USER='courthive'
PG_PASSWORD=''
PG_DATABASE='courthive'

MAILGUN_API_KEY=''
MAILGUN_DOMAIN='m.courthive.com'
MAILGUN_HOST='api.eu.mailgun.net'

# Arena relay (Wave 1c)
INSTANCE_ROLE=local                            # 'local' (Mac mini in arena) | 'cloud' (public relay)
LOCAL_VENUE_ID=arena-dev-00                    # unique per Mac mini, used in cloud ingest auth
CLOUD_RELAY_URL=                               # e.g. https://relay.courthive.com (empty on local dev)
CLOUD_RELAY_API_KEY=                           # Bearer token for cloud ingest
CLOUD_RELAY_MAX_BATCH=50                       # max entries sent per drain attempt
CLOUD_RELAY_DRAIN_INTERVAL_MS=5000             # how often the sender drains when idle
VENUE_API_KEYS=                                # cloud-only: comma-separated venueId:key pairs (e.g. arena-1:abc,arena-2:def)

# Tournament sync (local-only: pull tournaments from upstream cloud instance)
UPSTREAM_SERVER_URL=                           # e.g. https://courthive-nest.example.com (cloud factory-server)
UPSTREAM_API_KEY=                              # service-to-service Bearer token for upstream

# Projector consumers (Wave 2b)
SCORE_RELAY_URL=http://localhost:8384          # base URL of local score-relay; registers scorebug + video-board consumers
SCORE_RELAY_API_KEY=                           # Bearer token for score-relay projection intake routes
EXPRESSION_URL=                                # direct URL of Expression broadcast scorebug (optional)
EXPRESSION_API_KEY=                            # Bearer token for Expression (optional)
VIDEO_BOARD_URL=                               # direct URL of video board renderer (optional)
VIDEO_BOARD_API_KEY=                           # Bearer token for video board (optional)
SCOREBUG_TICK_INTERVAL_MS=250                  # clock tick cadence in ms (range 50–5000, default 250 = 4Hz)

# Score relay (runs as PM2 app "Score-Relay" from score-relay/dist/server.js)
RELAY_PORT=8384
CORS_ORIGIN=*
STALE_MATCH_HOURS=6
PRUNE_INTERVAL_MINUTES=30
FACTORY_SERVER_URL=http://localhost:8383       # factory server URL for match history persistence
PERSIST_SCORES=true
PROJECTION_API_KEY=                            # must match SCORE_RELAY_API_KEY above
VIDEO_BOARD_UDP_TARGET=                        # optional host:port for sub-frame UDP forwarding
