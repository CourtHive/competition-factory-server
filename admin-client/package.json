{
  "name": "competition-factory-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "lint": "eslint src --fix --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:prod": "TEST_PROD=1 playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "animate.css": "^4.1.1",
    "axios": "^1.13.0",
    "courthive-components": "^1.1.1",
    "i18next": "^26.0.0",
    "jwt-decode": "^4.0.0",
    "navigo": "^8.11.1",
    "tabulator-tables": "^6.3.1",
    "tods-competition-factory": ">=3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/html": "^10.2.17",
    "@storybook/html-vite": "^10.2.17",
    "happy-dom": "^20.8.3",
    "storybook": "^10.2.17",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.16"
  }
