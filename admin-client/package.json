{
  "name": "competition-factory-admin",
  "packageManager": "pnpm@11.5.2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check-types": "tsc --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "lint": "eslint src --fix --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:prod": "TEST_PROD=1 playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@courthive/provider-config": "^0.5.0",
    "animate.css": "^4.1.1",
    "axios": "^1.13.0",
    "courthive-components": "3.1.0",
    "i18next": "^26.0.0",
    "jwt-decode": "^4.0.0",
    "navigo": "^8.11.1",
    "tabulator-tables": "^6.3.1",
    "tods-competition-factory": "5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/html": "^10.2.17",
    "@storybook/html-vite": "^10.2.17",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.0.0",
    "happy-dom": "^20.8.3",
    "storybook": "^10.2.17",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.16"
  }
}
