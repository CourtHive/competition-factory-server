# Disable pnpm v11 verify-deps-before-run inside scripts/hooks. Lockfiles can
# be briefly stale (package.json edits in flight before pnpm install runs;
# mentat-pull-all.sh deletes lockfiles before each build cycle) so the check
# is noise without added safety in this ecosystem. See pnpm.io/npmrc.
verify-deps-before-run=false

# Skip the interactive "removing node_modules" prompt that fires when pnpm
# detects a packageManager/pnpm version change. Required for non-TTY contexts
# like husky pre-commit hooks and mentat-build-all.sh.
confirm-modules-purge=false

# Disable pnpm v11's supply-chain freshness policy. CourtHive-owned deps
# (factory, components, provider-config, i18n) are frequently fresh-from-publish
# and the policy false-positives the lockfile. The equivalent setting in
# pnpm-workspace.yaml is bypassed here because mentat-build-all.sh installs
# this sub-package with `--ignore-workspace`; .npmrc still applies.
minimum-release-age=0
